const calculateRSI = (history, periods = 14) => {
  if (history.length <= periods) return 50;
  let gains = 0, losses = 0;
  for (let i = history.length - periods; i < history.length; i++) {
    const diff = history[i].close - history[i - 1].close;
    if (diff >= 0) gains += diff;
    else losses -= diff;
  }
  const avgGain = gains / periods;
  const avgLoss = Math.abs(losses / periods);
  if (avgLoss === 0) return 100;
  const rs = avgGain / avgLoss;
  return 100 - (100 / (1 + rs));
};

export default function App() {
  const [activeCoin, setActiveCoin] = useState('BTC');
  const [activeTimeframe, setActiveTimeframe] = useState('1m'); 
  const [livePrice, setLivePrice] = useState(COINS.BTC.basePrice);
  const [predictionConfidence, setPredictionConfidence] = useState(85);
  const [wyckoffPhase, setWyckoffPhase] = useState('ACCUMULATION');
  const [candleProgress, setCandleProgress] = useState(0);
  const [isAutoScaled, setIsAutoScaled] = useState(true); 
  const [marketStats, setMarketStats] = useState({ change24h: 0, high24h: 0, low24h: 0, vol24h: 0, rsi: 50 });
  
  // נתוני חדשות, סנטימנט ומדד פחד ותאוות בצע
  const [newsData, setNewsData] = useState([]);
  const [sentimentScore, setSentimentScore] = useState(0); // -100 to 100
  const [isFetchingNews, setIsFetchingNews] = useState(true);
  const [fearGreed, setFearGreed] = useState({ value: 50, classification: 'Loading...' });

  const canvasRef = useRef(null);
  const containerRef = useRef(null);
  
  // Ref לשמירת הציון של המדד כדי שיהיה נגיש לפונקציית החיזוי
  const fearGreedRef = useRef(50);
  
  const viewRef = useRef({
    panX: 0, panY: 0, zoomX: 1, zoomY: 1, autoY: true, initialized: false, autoMinPrice: 0, autoMaxPrice: 1
  });
  
  const marketDataRef = useRef({
    BTC: { history: [], currentCandle: null, prediction: [], phase: 'ACCUMULATION' },
    ETH: { history: [], currentCandle: null, prediction: [], phase: 'ACCUMULATION' },
    SOL: { history: [], currentCandle: null, prediction: [], phase: 'ACCUMULATION' }
  });

  // --- משיכת מדד Fear & Greed ---
  useEffect(() => {
    let isMounted = true;
    const fetchFNG = async () => {
      try {
        const res = await fetch('https://api.alternative.me/fng/');
        if (!res.ok) throw new Error("Failed to fetch FNG");
        const data = await res.json();
        if (isMounted && data && data.data && data.data.length > 0) {
          const val = parseInt(data.data[0].value);
          fearGreedRef.current = val;
          setFearGreed({
            value: val,
            classification: data.data[0].value_classification
          });
        }
      } catch (e) {
        console.error("Fear & Greed Fetch Error:", e);
      }
    };
    
    fetchFNG();
    const interval = setInterval(fetchFNG, 3600000); // מתעדכן רשמית פעם ביום, אבל נבדוק כל שעה למקרה של שינוי
    return () => { isMounted = false; clearInterval(interval); };
  }, []);

  // --- מנוע משיכת חדשות וניתוח NLP ---
  useEffect(() => {
    let isMounted = true;
    
    const fetchAndAnalyzeNews = async () => {
      setIsFetchingNews(true);
      try {
        const res = await fetch('https://api.rss2json.com/v1/api.json?rss_url=https%3A%2F%2Fcointelegraph.com%2Frss');
        if (!res.ok) throw new Error("Failed to fetch RSS");
        const data = await res.json();
        if (!isMounted) return;

        const articles = data.items.slice(0, 15);
        const keyword = COINS[activeCoin].keyword;
        
        let totalScore = 0;
        let matchedArticles = [];

        articles.forEach(article => {
          const text = (article.title + " " + article.description).toLowerCase();
          const isRelevant = text.includes(keyword) || text.includes('crypto') || text.includes('market');
          
          let articleScore = 0;
          if (isRelevant) {
             SENTIMENT_DICT.bullish.forEach(word => { if (text.includes(word)) articleScore += 10; });
             SENTIMENT_DICT.bearish.forEach(word => { if (text.includes(word)) articleScore -= 10; });
             
             articleScore = Math.max(-30, Math.min(30, articleScore));
             totalScore += articleScore;
             
             matchedArticles.push({
               title: article.title,
               link: article.link,
               time: new Date(article.pubDate).toLocaleTimeString('he-IL', { hour: '2-digit', minute:'2-digit' }),
               score: articleScore
             });
          }
        });

        const finalSentiment = Math.max(-100, Math.min(100, totalScore));
        
        setNewsData(matchedArticles);
        setSentimentScore(finalSentiment);
        setIsFetchingNews(false);
        
        generatePrediction(activeCoin, finalSentiment);

      } catch (error) {
        console.error("News Fetch Error:", error);
        setIsFetchingNews(false);
      }
    };

    fetchAndAnalyzeNews();
    const newsInterval = setInterval(fetchAndAnalyzeNews, 60000 * 5);

    return () => {
      isMounted = false;
      clearInterval(newsInterval);
    };
  }, [activeCoin]);

  // חיבור לנתוני אמת (Binance REST API + Interpolation)
  useEffect(() => {
    let isMounted = true;
    let syncInterval = null;
    let tickInterval = null;
    let lastReactUpdate = Date.now();

    const symbol = `${activeCoin}USDT`;
    const tfConfig = TIMEFRAMES[activeTimeframe];

    viewRef.current.initialized = false;
    viewRef.current.autoY = true;
    setIsAutoScaled(true);

    const syncWithBinance = async () => {
      try {
        const res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${symbol}&interval=${tfConfig.binance}&limit=${MAX_HISTORY}`);
        if (!res.ok) return;
        const data = await res.json();
        
        const tickerRes = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbol=${symbol}`);
        const tickerData = tickerRes.ok ? await tickerRes.json() : null;

        if (!isMounted) return;

        const history = data.slice(0, -1).map(d => ({
          open: parseFloat(d[1]), high: parseFloat(d[2]), low: parseFloat(d[3]), close: parseFloat(d[4])
        }));

        const rsiVal = calculateRSI(history);

        if (tickerData) {
          setMarketStats({
            change24h: parseFloat(tickerData.priceChangePercent),
            high24h: parseFloat(tickerData.highPrice),
            low24h: parseFloat(tickerData.lowPrice),
            vol24h: parseFloat(tickerData.quoteVolume),
            rsi: rsiVal
          });
        }

        const currentRaw = data[data.length - 1];
        const currentCandle = {
          open: parseFloat(currentRaw[1]), high: parseFloat(currentRaw[2]), low: parseFloat(currentRaw[3]), close: parseFloat(currentRaw[4]),
          startTime: currentRaw[0], closeTime: currentRaw[6]
        };

        const coinData = marketDataRef.current[activeCoin];
        coinData.history = history;
        coinData.currentCandle = currentCandle;

        generatePrediction(activeCoin, sentimentScore);
      } catch (error) {
        console.error("Failed to sync Binance data:", error);
      }
    };

    const simulateSmoothTick = () => {
      const coinData = marketDataRef.current[activeCoin];
      if (!coinData.currentCandle) return;

      const now = Date.now();
      const currentCandle = coinData.currentCandle;
      
      const progress = Math.min(100, Math.max(0, ((now - currentCandle.startTime) / (currentCandle.closeTime - currentCandle.startTime)) * 100));

      if (!coinData.tickMomentum) coinData.tickMomentum = 0;
      coinData.tickMomentum = coinData.tickMomentum * 0.9 + (Math.random() - 0.5) * 0.1;
      
      const tickVolatility = COINS[activeCoin].volatility * 0.02; 
      const change = currentCandle.close * tickVolatility * coinData.tickMomentum;
      const newPrice = currentCandle.close + change;

      currentCandle.close = newPrice;
      if (newPrice > currentCandle.high) currentCandle.high = newPrice;
      if (newPrice < currentCandle.low) currentCandle.low = newPrice;

      if (now - lastReactUpdate > 100) {
        setLivePrice(newPrice);
        setCandleProgress(progress);
        setWyckoffPhase(prevPhase => prevPhase !== coinData.phase ? coinData.phase : prevPhase);
        lastReactUpdate = now;
      }
    };

    syncWithBinance();
    syncInterval = setInterval(syncWithBinance, 3000); 
    tickInterval = setInterval(simulateSmoothTick, TICK_RATE);

    return () => {
      isMounted = false;
      clearInterval(syncInterval);
      clearInterval(tickInterval);
    };
  }, [activeTimeframe, activeCoin, sentimentScore]); 

  // --- מנוע הכלאה: Wyckoff + News Sentiment + Fear & Greed ---
  const generatePrediction = (coin, currentSentiment) => {
    const data = marketDataRef.current[coin];
    const history = data.history;
    if (history.length < 20) return;

    const lookback = Math.min(60, history.length);
    const contextPrices = history.slice(-lookback).map(c => c.close);
    const currentPrice = data.currentCandle.close;

    const minContext = Math.min(...contextPrices, currentPrice);
    const maxContext = Math.max(...contextPrices, currentPrice);
    const range = maxContext - minContext || 1;
    
    const relPos = (currentPrice - minContext) / range;
    const momShort = currentPrice - contextPrices[contextPrices.length - Math.min(10, contextPrices.length)];
    const momLong = currentPrice - contextPrices[0];

    let phase = data.phase;

    if (phase === 'ACCUMULATION' && relPos > 0.65 && momLong > 0) phase = 'MARKUP';
    if (phase === 'MARKUP' && relPos > 0.8 && momShort < 0) phase = 'DISTRIBUTION';
    if (phase === 'DISTRIBUTION' && relPos < 0.35 && momLong < 0) phase = 'MARKDOWN';
    if (phase === 'MARKDOWN' && relPos < 0.2 && momShort > 0) phase = 'ACCUMULATION';

    if (!phase) {
      if (relPos > 0.7) phase = 'DISTRIBUTION';
      else if (relPos < 0.3) phase = 'ACCUMULATION';
      else if (momLong > 0) phase = 'MARKUP';
      else phase = 'MARKDOWN';
    }

    data.phase = phase;
    if (Math.random() > 0.99) setPredictionConfidence(Math.floor(78 + Math.random() * 15)); 

    const predictions = [];
    const tf = TIMEFRAMES[activeTimeframe];
    const volatilityScale = Math.sqrt(tf.minutes);
    const baseVol = COINS[coin].volatility * volatilityScale;
    
    let predPrice = currentPrice;
    const time = Date.now() / 1000;

    // שילוב מוחלט: Fear & Greed Index + תמונת החדשות מה-NLP
    // מנרמל את F&G מ-0-100 ל -100 עד 100
    const fngNormalized = (fearGreedRef.current - 50) * 2; 
    
    // משקלל 60% חדשות אקטואליות ו-40% סנטימנט גלובלי מתמשך
    const combinedSentimentScore = (currentSentiment * 0.6) + (fngNormalized * 0.4);

    // פקטור סנטימנט סופי שמשפיע על השיפוע של החיזוי
    const sentimentBias = (combinedSentimentScore / 100) * baseVol * currentPrice * 1.5;

    for (let i = 0; i < PREDICTION_STEPS; i++) {
      const progress = i / PREDICTION_STEPS;
      let wyckoffCurve = 0;

      switch(phase) {
        case 'ACCUMULATION':
          if (progress < 0.35) wyckoffCurve = -Math.sin((progress / 0.35) * Math.PI) * 1.5;
          else wyckoffCurve = Math.pow((progress - 0.35) / 0.65, 2) * 4;
          break;
        case 'MARKUP':
          wyckoffCurve = progress * 4 + Math.sin(progress * Math.PI * 2) * 1.0;
          break;
        case 'DISTRIBUTION':
          if (progress < 0.35) wyckoffCurve = Math.sin((progress / 0.35) * Math.PI) * 1.5;
          else wyckoffCurve = -Math.pow((progress - 0.35) / 0.65, 2) * 4;
          break;
        case 'MARKDOWN':
          wyckoffCurve = -progress * 4 + Math.sin(progress * Math.PI * 2) * 1.0;
          break;
        default:
          wyckoffCurve = 0;
      }

      const appliedSentiment = sentimentBias * (1 - progress * 0.5);
      const targetOffset = wyckoffCurve * baseVol * currentPrice * 1.5; 
      const stepTarget = currentPrice + targetOffset + appliedSentiment;

      const smoothNoise = (Math.sin(time * 2 + i * 0.5) + Math.cos(time * 1.5 - i * 0.3)) * 0.3;
      const uncertainty = 1 + (progress * 0.5); 
      
      // תנודתיות (פניקה) גדלה ככל שהשוק מקצין לצד כלשהו
      const panicMultiplier = 1 + (Math.abs(combinedSentimentScore) / 100);
      const noiseOffset = currentPrice * baseVol * smoothNoise * uncertainty * panicMultiplier;

      const close = stepTarget + noiseOffset;
      const wickHighFactor = Math.abs(Math.sin(time * 3 + i)) * panicMultiplier;
      const wickLowFactor = Math.abs(Math.cos(time * 3 + i)) * panicMultiplier;
      const high = Math.max(predPrice, close) + currentPrice * baseVol * wickHighFactor;
      const low = Math.min(predPrice, close) - currentPrice * baseVol * wickLowFactor;

      predictions.push({ open: predPrice, high, low, close });
      predPrice = close;
    }
    data.prediction = predictions;
  };

  // מנהלי אירועים לעכבר
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    let isDragging = false;
    let lastX = 0; let lastY = 0;

    const handleMouseDown = (e) => { isDragging = true; lastX = e.clientX; lastY = e.clientY; canvas.style.cursor = 'grabbing'; };
    const handleMouseMove = (e) => {
      if (!isDragging) return;
      const dx = e.clientX - lastX; const dy = e.clientY - lastY;
      lastX = e.clientX; lastY = e.clientY;
      viewRef.current.panX += dx;
      if (Math.abs(dy) > 2) { viewRef.current.autoY = false; viewRef.current.panY += dy; setIsAutoScaled(false); }
    };
    const handleMouseUp = () => { isDragging = false; canvas.style.cursor = 'crosshair'; };
    const handleWheel = (e) => {
      e.preventDefault();
      const rect = canvas.getBoundingClientRect();
      const mouseX = e.clientX - rect.left; const mouseY = e.clientY - rect.top;
      const zoomFactor = e.deltaY < 0 ? 1.05 : 0.95;

      if (e.shiftKey || e.ctrlKey) {
        viewRef.current.autoY = false; setIsAutoScaled(false);
        const yBase = (mouseY - viewRef.current.panY) / viewRef.current.zoomY;
        viewRef.current.zoomY *= zoomFactor;
        viewRef.current.panY = mouseY - yBase * viewRef.current.zoomY;
      } else {
        const xBase = (mouseX - viewRef.current.panX) / viewRef.current.zoomX;
        viewRef.current.zoomX *= zoomFactor;
        viewRef.current.zoomX = Math.max(0.1, Math.min(viewRef.current.zoomX, 20));
        viewRef.current.panX = mouseX - xBase * viewRef.current.zoomX;
      }
    };
    const handleDoubleClick = () => resetView();

    canvas.addEventListener('mousedown', handleMouseDown);
    window.addEventListener('mousemove', handleMouseMove);
    window.addEventListener('mouseup', handleMouseUp);
    canvas.addEventListener('wheel', handleWheel, { passive: false });
    canvas.addEventListener('dblclick', handleDoubleClick);

    return () => {
      canvas.removeEventListener('mousedown', handleMouseDown); window.removeEventListener('mousemove', handleMouseMove);
      window.removeEventListener('mouseup', handleMouseUp); canvas.removeEventListener('wheel', handleWheel);
      canvas.removeEventListener('dblclick', handleDoubleClick);
    };
  }, []);

  const resetView = () => {
    viewRef.current.autoY = true; viewRef.current.panY = 0; viewRef.current.zoomY = 1; setIsAutoScaled(true);
    const canvas = canvasRef.current;
    if (canvas && marketDataRef.current[activeCoin].history.length > 0) {
      const actualWidth = 8 * viewRef.current.zoomX;
      const currentX = marketDataRef.current[activeCoin].history.length * actualWidth;
      const rect = canvas.getBoundingClientRect();
      viewRef.current.panX = (rect.width * 0.75) - currentX;
    }
  };

  // רינדור קנבס
  useEffect(() => {
    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d', { alpha: false });
    let animationFrameId;

    const render = () => {
      const rect = containerRef.current.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      
      if (canvas.width !== rect.width * dpr || canvas.height !== rect.height * dpr) {
        canvas.width = rect.width * dpr; canvas.height = rect.height * dpr; ctx.scale(dpr, dpr);
      }
      const width = rect.width; const height = rect.height;

      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0, 0, width, height);

      const coinData = marketDataRef.current[activeCoin];
      if (!coinData.currentCandle) { animationFrameId = requestAnimationFrame(render); return; }
      
      const fullData = [...coinData.history, coinData.currentCandle, ...coinData.prediction];
      if (fullData.length === 0) return;

      const baseCandleWidth = 8;
      const actualCandleWidth = baseCandleWidth * viewRef.current.zoomX;

      if (!viewRef.current.initialized) {
        const currentX = coinData.history.length * actualCandleWidth;
        viewRef.current.panX = (width * 0.75) - currentX; viewRef.current.initialized = true;
      }

      const startI = Math.max(0, Math.floor(-viewRef.current.panX / actualCandleWidth));
      const endI = Math.min(fullData.length - 1, Math.ceil((width - viewRef.current.panX) / actualCandleWidth));

      let minPrice = Infinity; let maxPrice = -Infinity;
      
      if (viewRef.current.autoY) {
         for (let i = startI; i <= endI; i++) {
           if (fullData[i]) {
              if (fullData[i].low < minPrice) minPrice = fullData[i].low;
              if (fullData[i].high > maxPrice) maxPrice = fullData[i].high;
           }
         }
         if (minPrice === Infinity) { minPrice = 0; maxPrice = 1; }
         const padding = (maxPrice - minPrice) * 0.15;
         minPrice -= padding; maxPrice += padding;
         viewRef.current.autoMinPrice = minPrice; viewRef.current.autoMaxPrice = maxPrice;
      } else {
         minPrice = viewRef.current.autoMinPrice; maxPrice = viewRef.current.autoMaxPrice;
      }

      const priceRange = Math.max(maxPrice - minPrice, 0.0001); 
      const getY = (price) => {
        let base_y = height - ((price - minPrice) / priceRange) * height;
        return base_y * viewRef.current.zoomY + viewRef.current.panY;
      };

      ctx.strokeStyle = 'rgba(255,255,255,0.03)'; ctx.beginPath();
      const gridStepX = Math.max(1, Math.floor(60 / actualCandleWidth)); 
      for (let i = startI; i <= endI; i++) {
        if (i % gridStepX === 0) {
           const x = i * actualCandleWidth + viewRef.current.panX + actualCandleWidth/2;
           ctx.moveTo(x, 0); ctx.lineTo(x, height);
        }
      }
      for (let i = 0; i < 10; i++) {
         const y = (i / 10) * height * viewRef.current.zoomY + viewRef.current.panY;
         ctx.moveTo(0, y); ctx.lineTo(width, y);
      }
      ctx.stroke();

      const predictionStartX = (coinData.history.length + 1) * actualCandleWidth + viewRef.current.panX;
      
      if (predictionStartX < width) {
        const predGradient = ctx.createLinearGradient(predictionStartX, 0, width, 0);
        predGradient.addColorStop(0, 'rgba(0, 240, 255, 0.0)');
        predGradient.addColorStop(1, 'rgba(0, 240, 255, 0.08)');
        ctx.fillStyle = predGradient; ctx.fillRect(predictionStartX, 0, width - predictionStartX, height);
        
        ctx.beginPath(); ctx.setLineDash([5, 5]); ctx.moveTo(predictionStartX, 0); ctx.lineTo(predictionStartX, height);
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)'; ctx.lineWidth = 1; ctx.stroke(); ctx.setLineDash([]); 

        ctx.fillStyle = 'rgba(255, 255, 255, 0.6)'; ctx.font = '10px monospace'; ctx.fillText('LIVE NOW', predictionStartX + 5, 15);
      }

      const drawCandle = (c, index, isPrediction) => {
        const x = index * actualCandleWidth + viewRef.current.panX;
        if (x + actualCandleWidth < 0 || x > width) return;

        const centerX = x + actualCandleWidth / 2;
        const yOpen = getY(c.open); const yClose = getY(c.close);
        const yHigh = getY(c.high); const yLow = getY(c.low);
        
        const isUp = c.close >= c.open;
        let colorUp = '#00ff88'; let colorDown = '#ff3366';
        
        if (isPrediction) {
          colorUp = 'rgba(0, 255, 136, 0.5)'; colorDown = 'rgba(255, 51, 102, 0.5)';
          ctx.shadowBlur = 10; ctx.shadowColor = isUp ? '#00ff88' : '#ff3366';
        } else {
          ctx.shadowBlur = 0;
        }

        ctx.strokeStyle = isUp ? colorUp : colorDown; ctx.fillStyle = isUp ? colorUp : colorDown;

        ctx.beginPath(); ctx.moveTo(centerX, yHigh); ctx.lineTo(centerX, yLow);
        ctx.lineWidth = isPrediction ? 1.5 : 1.5; ctx.stroke();

        const bodyHeight = Math.abs(yClose - yOpen); const bodyY = isUp ? yClose : yOpen;
        const cWidth = actualCandleWidth * 0.7; const cX = centerX - cWidth / 2;

        if (isPrediction) {
          ctx.strokeRect(cX, Math.max(bodyY, 1), cWidth, Math.max(bodyHeight, 1));
        } else {
          ctx.fillRect(cX, Math.max(bodyY, 1), cWidth, Math.max(bodyHeight, 1));
        }
        ctx.shadowBlur = 0; 
      };

      [...coinData.history, coinData.currentCandle].forEach((c, i) => drawCandle(c, i, false));
      coinData.prediction.forEach((c, i) => drawCandle(c, coinData.history.length + 1 + i, true));

      const liveY = getY(coinData.currentCandle.close);
      if (liveY > 0 && liveY < height) {
        ctx.beginPath(); ctx.setLineDash([2, 4]); ctx.moveTo(0, liveY); ctx.lineTo(width, liveY);
        ctx.strokeStyle = COINS[activeCoin].color; ctx.lineWidth = 1; ctx.stroke(); ctx.setLineDash([]);
        
