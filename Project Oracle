        ctx.fillStyle = '#000'; ctx.font = 'bold 11px monospace'; ctx.textAlign = 'right'; ctx.fillText(priceText, width - 5, liveY + 4);
        ctx.textAlign = 'left'; 
      }

      animationFrameId = requestAnimationFrame(render);
    };

    render();
    return () => cancelAnimationFrame(animationFrameId);
  }, [activeCoin]);

