      for (let p = startPrice; p <= endPrice; p += step) { const y = getY(p); if (y >= 0 && y <= chartH) { const priceText = p > 10 ? p.toFixed(2) : p.toFixed(4); ctx.fillText(priceText, Y_AXIS_W / 2, y); } }
      if (liveY > 0 && liveY < chartH) { const priceText = coinData.currentCandle.close.toFixed(2); ctx.fillStyle = COINS[activeCoin].color; ctx.fillRect(0, liveY - 10, Y_AXIS_W, 20); ctx.fillStyle = '#000'; ctx.font = 'bold 11px monospace'; ctx.fillText(priceText, Y_AXIS_W / 2, liveY); }

      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(Y_AXIS_W, chartH, chartW, X_AXIS_H); ctx.strokeStyle = 'rgba(255,255,255,0.1)'; ctx.beginPath(); ctx.moveTo(Y_AXIS_W, chartH); ctx.lineTo(width, chartH); ctx.stroke();
      ctx.fillStyle = '#888'; ctx.font = '10px monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      for (let i = startI; i <= endI; i++) {
        if (i % gridStepX === 0) {
           const x = i * actualCandleWidth + viewRef.current.panX + actualCandleWidth/2 + Y_AXIS_W;
           if (x > Y_AXIS_W && x < width) {
               ctx.beginPath(); ctx.moveTo(x, chartH); ctx.lineTo(x, chartH + 5); ctx.stroke(); 
               const candle = fullData[i]; let timeStr = '';
               if (candle && candle.startTime) { timeStr = new Date(candle.startTime).toLocaleTimeString('he-IL', {hour: '2-digit', minute:'2-digit'}); } 
               else if (i > coinData.history.length) { const candleDurationMs = TIMEFRAMES[activeTimeframe].minutes * 60 * 1000; const estimatedTime = coinData.currentCandle.startTime + ((i - coinData.history.length) * candleDurationMs); timeStr = new Date(estimatedTime).toLocaleTimeString('he-IL', {hour: '2-digit', minute:'2-digit'}); }
               if (timeStr) ctx.fillText(timeStr, x, chartH + 8);
           }
        }
      }
      ctx.fillStyle = '#050508'; ctx.fillRect(0, chartH, Y_AXIS_W, X_AXIS_H);

      animationFrameId = requestAnimationFrame(render);
    };

    render(); return () => cancelAnimationFrame(animationFrameId);
  }, [activeCoin, riskData, openTrades]);

