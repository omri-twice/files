             <div>
                <div className="flex justify-between items-center mb-1"><span className="text-[10px] text-white/50 font-mono font-bold">FEAR & GREED</span><div className="flex items-center gap-2"><span className="text-[9px] text-white/40">{fearGreed.classification}</span><span className={`text-xs font-bold font-mono ${fearGreed.value > 55 ? 'text-green-400' : fearGreed.value < 45 ? 'text-red-400' : 'text-yellow-400'}`}>{fearGreed.value !== null ? fearGreed.value : '--'}</span></div></div>
                <div className="h-1.5 w-full rounded-full overflow-hidden relative flex bg-white/10"><div className="h-full bg-red-600 w-[25%]"></div><div className="h-full bg-orange-500 w-[20%]"></div><div className="h-full bg-yellow-500 w-[10%]"></div><div className="h-full bg-green-400 w-[20%]"></div><div className="h-full bg-green-600 w-[25%]"></div>{fearGreed.value !== null && (<div className="absolute top-0 bottom-0 w-1 bg-white shadow-[0_0_5px_white]" style={{ left: `${fearGreed.value}%`, transform: 'translateX(-50%)' }}></div>)}</div>
             </div>
             <div>
                <div className="flex justify-between items-center mb-1"><span className="text-[10px] text-white/50 font-mono font-bold">NLP SENTIMENT</span><span className={`text-xs font-bold font-mono ${sentimentScore > 20 ? 'text-green-400' : sentimentScore < -20 ? 'text-red-400' : 'text-yellow-400'}`}>{sentimentScore > 0 ? '+' : ''}{sentimentScore.toFixed(0)}</span></div>
                <div className="h-1.5 w-full bg-white/10 rounded-full overflow-hidden relative"><div className="absolute left-1/2 top-0 bottom-0 w-px bg-white/30 z-10"></div><div className={`absolute top-0 bottom-0 transition-all duration-1000 ${sentimentScore >= 0 ? 'bg-green-500 right-1/2' : 'bg-red-500 left-1/2'}`} style={{ width: `${Math.abs(sentimentScore) / 2}%`, [sentimentScore >= 0 ? 'left' : 'right']: '50%' }}></div></div>
             </div>
          </div>

          {(() => {
            const ob = marketDataRef.current[activeCoin]?.orderBook; let bidVol = 0, askVol = 0;
            if (ob && ob.bids.length > 0) { bidVol = ob.bids.reduce((s, b) => s + b.qty, 0); askVol = ob.asks.reduce((s, a) => s + a.qty, 0); }
            const totalVol = bidVol + askVol || 1; const bidPct = (bidVol / totalVol) * 100;
            return (
              <div className="bg-black/40 rounded-xl p-3 border border-white/5 shrink-0 flex flex-col gap-2 shadow-inner">
                 <div className="flex justify-between items-center"><span className="text-[10px] font-bold text-white/60 uppercase tracking-widest">Order Flow Imbalance</span><span className={`text-[10px] font-mono font-bold ${bidPct > 55 ? 'text-green-400' : bidPct < 45 ? 'text-red-400' : 'text-yellow-400'}`}>{bidPct > 55 ? 'BUY PRESSURE' : bidPct < 45 ? 'SELL PRESSURE' : 'NEUTRAL'}</span></div>
                 <div className="h-1.5 w-full rounded-full overflow-hidden flex bg-white/10"><div className="h-full bg-green-500 transition-all duration-500" style={{ width: `${bidPct}%` }}></div><div className="h-full bg-red-500 transition-all duration-500" style={{ width: `${100 - bidPct}%` }}></div></div>
                 <div className="flex justify-between text-[9px] text-white/40 font-mono"><span>Bids: {bidPct.toFixed(1)}%</span><span>Asks: {(100 - bidPct).toFixed(1)}%</span></div>
              </div>
            );
          })()}

          <div className="bg-black/40 rounded-xl p-4 border border-red-500/20 relative shadow-[0_0_30px_rgba(255,51,102,0.05)] shrink-0 flex flex-col gap-3">
             <div className="flex items-center gap-2 mb-1"><div className="w-4 h-4 text-red-400 animate-pulse"><Icons.Activity /></div><h2 className="text-red-400 font-bold text-sm">נגזרים וחיסולים (Live)</h2></div>
             <div><div className="flex justify-between text-[10px] text-white/50 mb-1 font-mono"><span>Longs</span><span>Shorts</span></div><div className="h-2 w-full rounded-full overflow-hidden flex bg-white/10"><div className="h-full bg-green-500 transition-all duration-500" style={{ width: `${lsRatio}%` }}></div><div className="h-full bg-red-500 transition-all duration-500" style={{ width: `${100 - lsRatio}%` }}></div></div><div className="flex justify-between text-[10px] text-white/80 mt-1 font-mono font-bold"><span>{lsRatio.toFixed(1)}%</span><span>{(100 - lsRatio).toFixed(1)}%</span></div></div>
             <div className="flex-1 min-h-[80px] bg-black/50 rounded border border-white/5 p-2 overflow-y-auto space-y-1 scrollbar-hide">
               {liquidations.length === 0 ? <div className="text-xs text-white/30 italic text-center mt-4">ממתין לתנודה חדה...</div> : liquidations.map((liq, idx) => ( <div key={idx} className="flex justify-between items-center text-[10px] font-mono animate-[fadeIn_0.3s_ease-in-out]"><span className="text-white/40">{liq.time}</span><span className={`${liq.type === 'LONG' ? 'text-red-400' : 'text-green-400'}`}>🔥 Liq {liq.type}: ${liq.amt}K</span></div> ))}
             </div>
          </div>

          <div className="flex-1 flex flex-col gap-2 min-h-[120px] shrink-0">
            <h3 className="text-[10px] font-bold text-white/60 uppercase tracking-widest flex items-center gap-2 border-b border-white/10 pb-2"><div className="w-3 h-3 text-cyan-400 animate-pulse"><Icons.Anchor /></div> ON-CHAIN WHALE ALERTS</h3>
            <div className="space-y-2 overflow-y-auto">{whaleAlerts.length === 0 ? <div className="text-xs text-white/30 italic mt-2">Listening to mempool...</div> : whaleAlerts.map((alert, idx) => (<div key={idx} className={`text-[10px] font-mono p-2 rounded border ${alert.includes('BUY') ? 'bg-green-500/10 border-green-500/20 text-green-300' : 'bg-red-500/10 border-red-500/20 text-red-300'} animate-[fadeIn_0.5s_ease-in-out]`}>{alert}</div>))}</div>
          </div>

          <div className="flex-1 flex flex-col gap-2 min-h-[150px]">
            <h3 className="text-[10px] font-bold text-white/60 uppercase tracking-widest flex items-center gap-2 border-b border-white/10 pb-2"><div className="w-3 h-3 text-purple-400"><Icons.Newspaper /></div> LIVE NEWS</h3>
            <div className="space-y-2 overflow-y-auto pr-1">
              {newsData.map((article, idx) => (<a key={idx} href={article.link} target="_blank" rel="noreferrer" className="block bg-white/5 hover:bg-white/10 p-2 rounded border border-white/5 group"><div className="flex justify-between items-start mb-1"><span className="text-[9px] font-mono text-white/40">{article.time}</span><span className={`text-[9px] font-mono px-1 rounded ${article.score > 0 ? 'bg-green-500/20 text-green-400' : article.score < 0 ? 'bg-red-500/20 text-red-400' : 'bg-white/10 text-white/50'}`}>{article.score > 0 ? 'BULL' : article.score < 0 ? 'BEAR' : 'NEU'}</span></div><h4 className="text-[10px] text-white/80 group-hover:text-blue-400 leading-tight line-clamp-2" dir="ltr">{article.title}</h4></a>))}
            </div>
          </div>
        </div>

      </div>
    </div>
  );
}
