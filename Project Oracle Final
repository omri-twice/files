const calculateRSI = (history, periods = 14) => {
  if (history.length <= periods) return 50;
  let gains = 0, losses = 0;
  for (let i = history.length - periods; i < history.length; i++) {
    const diff = history[i].close - history[i - 1].close;
    if (diff >= 0) gains += diff; else losses -= diff;
  }
  const avgGain = gains / periods; const avgLoss = Math.abs(losses / periods);
  if (avgLoss === 0) return 100;
  return 100 - (100 / (1 + avgGain / avgLoss));
};

const calculateATR = (history, periods = 14) => {
  if (history.length <= periods) return 0;
  let trSum = 0;
  for (let i = history.length - periods; i < history.length; i++) {
    const high = history[i].high; const low = history[i].low; const prevClose = history[i - 1].close;
    const tr = Math.max(high - low, Math.abs(high - prevClose), Math.abs(low - prevClose));
    trSum += tr;
  }
  return trSum / periods;
};

const calculateEMA = (data, period) => {
  const k = 2 / (period + 1);
  let ema = data[0]; const emaArray = [ema];
  for (let i = 1; i < data.length; i++) { ema = (data[i] * k) + (ema * (1 - k)); emaArray.push(ema); }
  return emaArray;
};

const calculateMACD = (history, shortP = 12, longP = 26, signalP = 9) => {
  if (history.length < longP + signalP) return { macd: 0, signal: 0, hist: 0 };
  const closes = history.map(h => h.close);
  const shortEMA = calculateEMA(closes, shortP); const longEMA = calculateEMA(closes, longP);
  const macdLine = shortEMA.map((s, i) => s - longEMA[i]); const signalLine = calculateEMA(macdLine, signalP);
  return { macd: macdLine[macdLine.length - 1], signal: signalLine[signalLine.length - 1], hist: macdLine[macdLine.length - 1] - signalLine[signalLine.length - 1] };
};

